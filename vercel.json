{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bun run build",
  "installCommand": "bun install",
  "outputDirectory": "dist/client",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node@2",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/((?!assets/).*)", "destination": "/api" }
  ]
}
